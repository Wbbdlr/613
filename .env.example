# ── 613 Self-Hosted Jewish Suite ──────────────────────────────────
# Copy this file to .env and adjust values before running.

# Host port published by the main docker-compose.yml.
# You can expose this directly or point Cloudflare Tunnel / another reverse proxy at it.
HTTP_PORT=8613

# Image tag used by the production compose stack.
# Default is the published stable release channel.
IMAGE_TAG=stable

# MeiliSearch master key (change this for production)
MEILI_MASTER_KEY=change_me_in_production

# JWT secret for user authentication — MUST be changed for production
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_in_production
