# ── 613 Self-Hosted Jewish Suite ──────────────────────────────────
# Copy this file to .env and adjust values before running.

# Optional overrides for docker-compose.yml.
# The stack runs without a .env file; add one only if you want to change defaults.

# Host port published by the main docker-compose.yml.
HTTP_PORT=8613

# JWT secret for user authentication — MUST be changed for production
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_in_production

# Optional for docker-compose.remote-build.yml to pin a branch or tag.
GIT_REF=main
