# ── 613 Self-Hosted Jewish Suite ──────────────────────────────────
# Copy this file to .env and adjust values before running.

# Ports exposed on the host (default 80 / 443)
HTTP_PORT=80
HTTPS_PORT=443

# MeiliSearch master key (change this for production)
MEILI_MASTER_KEY=change_me_in_production

# (Optional) Default location for Zmanim
DEFAULT_CITY=New York
DEFAULT_LAT=40.6501
DEFAULT_LON=-73.9496
DEFAULT_TZID=America/New_York

# Israel mode for Hebcal (true/false)
HEBCAL_IL=false
