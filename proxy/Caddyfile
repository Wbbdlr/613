{
    admin off
}

:{$HTTP_PORT:80} {
    # Service Worker must not be cached by Caddy so browsers always get the latest version
    header /sw.js Cache-Control "no-cache, no-store, must-revalidate"

    # Frontend (serves built React app including sw.js)
    handle {
        reverse_proxy frontend:3000
    }

    # Sefaria API
    handle /api/sefaria/* {
        uri strip_prefix /api/sefaria
        reverse_proxy sefaria-service:3002
    }
}
